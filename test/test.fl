@aflow {std}
@in_parma "Hello World"

model lib{
    map print("Hello World!")
    ->  parallel("true") {
        print("Hello World!"),
        print("hEllo wOrld!"),
        print(int_tuple`1,3,4,5`)
    }
    -> parallel {
        model a{
            print("23")
        },
        model b{
            print("234")
        }
    }
